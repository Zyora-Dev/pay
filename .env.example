# Zyora Pay - Environment Variables

# App
APP_NAME=Zyora Pay
DEBUG=true

# Database (create this DB: createdb zyora_pay)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zyora_pay

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:6006,https://ztunnel.dev,https://zyora.cloud

# Admin secret for managing apps and gateways via /v1/admin/* endpoints
ADMIN_SECRET=change-me-in-production

# Default webhook HMAC secret (each app gets its own secret on registration)
WEBHOOK_SECRET=webhook-hmac-secret-change-me
